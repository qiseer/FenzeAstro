---
// src/pages/blog/[page].astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export const prerender = true; // 显式声明静态生成（可选，默认就是）

// 每页显示数量
const PAGE_SIZE = 10;

// 获取所有文章
const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const totalPages = Math.ceil(sortedPosts.length / PAGE_SIZE);

// ✅ 关键：导出 getStaticPaths，告诉 Astro 要生成哪些页面
export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const allPosts = await getCollection("blog");
  const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

  // 生成 /blog/1, /blog/2, /blog/3... 的路径
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
  }));
}

// 获取当前页码
const { page } = Astro.params;
const currentPage = parseInt(page);

// 截取当前页文章
const start = (currentPage - 1) * PAGE_SIZE;
const posts = sortedPosts.slice(start, start + PAGE_SIZE);
---

<BaseLayout pageTitle={`博客 - 第${currentPage}页`}>
  <div class="blog-container">
    <h1>博客文章</h1>

    <div class="posts-grid">
      {
        posts.map((post) => (
          <article class="post-card">
            {post.data.image !== "none" && (
              <a href={`/blog/${post.id}/`} class="post-image-link">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="post-image"
                />
              </a>
            )}
            <div class="post-card-content">
              <h2>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("zh-CN", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                <span>·</span>
                <span>{post.data.author}</span>
              </div>
              {post.data.description && (
                <p class="post-description">{post.data.description}</p>
              )}
              <div class="tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.id}/`} class="read-more">
                阅读全文 →
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <!-- 分页导航 -->
    {
      totalPages > 1 && (
        <nav class="pagination">
          {currentPage > 1 ? (
            <a href={`/blog/${currentPage - 1}`} class="page-btn">
              ← 上一页
            </a>
          ) : (
            <span class="page-btn disabled">← 上一页</span>
          )}

          <div class="page-numbers">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) =>
              num === currentPage ? (
                <span class="page-num current">{num}</span>
              ) : (
                <a href={`/blog/${num}`} class="page-num">
                  {num}
                </a>
              ),
            )}
          </div>

          {currentPage < totalPages ? (
            <a href={`/blog/${currentPage + 1}`} class="page-btn">
              下一页 →
            </a>
          ) : (
            <span class="page-btn disabled">下一页 →</span>
          )}
        </nav>
      )
    }

    <div class="blog-stats">
      共 {sortedPosts.length} 篇文章，第 {currentPage}/{totalPages} 页
    </div>
  </div>
</BaseLayout>

<style>
  /* 保留你原有的样式... */
  .blog-container {
    max-width: 80ch;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  h1 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 2rem;
  }
  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .post-card {
    background: var(--color-bg-surface);
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .post-image-link {
    display: block;
    overflow: hidden;
  }
  .post-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .post-card:hover .post-image {
    transform: scale(1.02);
  }
  .post-card-content {
    padding: 1.5rem;
  }
  .post-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
  }
  .post-card h2 a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-card h2 a:hover {
    color: var(--color-primary);
  }
  .post-meta {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .post-description {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .tag {
    background: var(--color-bg-elevated);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }
  .read-more {
    display: inline-block;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    transition: transform 0.2s;
  }
  .read-more:hover {
    transform: translateX(4px);
  }

  /* 分页样式 */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .page-btn {
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .page-btn:hover:not(.disabled) {
    background: var(--color-primary);
    color: white;
  }

  .page-btn.disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .page-numbers {
    display: flex;
    gap: 0.5rem;
  }

  .page-num {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    text-decoration: none;
    font-size: 0.875rem;
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    transition: all 0.2s;
  }

  .page-num:hover:not(.current) {
    background: var(--color-primary);
    color: white;
  }

  .page-num.current {
    background: var(--color-primary);
    color: white;
    font-weight: 500;
  }

  .blog-stats {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  @media (max-width: 640px) {
    .blog-container {
      padding: 1rem;
    }
    .post-card-content {
      padding: 1rem;
    }
    .post-card h2 {
      font-size: 1.25rem;
    }
    .post-image {
      height: 150px;
    }
    .pagination {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .page-numbers {
      order: 3;
      width: 100%;
      justify-content: center;
    }
  }
</style>
