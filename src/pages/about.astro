---
// src/pages/about.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout pageTitle="关于我 | 蹊世">
  <div class="about-container">
    <!-- 头部区域：头像 + 简介 -->
    <div class="profile-section">
      <div class="avatar-wrapper">
        <img src="/fenze.png" alt="Qiseer 的头像" class="avatar" />
        <div class="avatar-glow"></div>
      </div>
      <div class="profile-text">
        <h1>你好，我是 <span class="gradient-text">Qiseer</span>（蹊世）</h1>
        <p class="tagline">全栈开发者 | 游戏爱好者 | 网络安全探索者</p>
        <p class="bio">
          热爱构建优雅、高效的应用，从 Web
          全栈到游戏开发，同时深耕网络安全领域。<br />
          相信技术可以改变世界，也享受创造过程中的每一份乐趣。
        </p>
      </div>
    </div>

    <!-- 技能卡片区域 -->
    <div class="skills-section">
      <h2>⚡ 技术栈</h2>
      <div class="skills-grid">
        <div class="skill-card">JavaScript / TypeScript</div>
        <div class="skill-card">React / Vue / Astro</div>
        <div class="skill-card">Node.js / Express</div>
        <div class="skill-card">Python / FastAPI</div>
        <div class="skill-card">C / C++</div>
        <div class="skill-card">Java</div>
        <div class="skill-card">C# / .NET</div>
        <div class="skill-card skill-planned">Rust (计划学习)</div>
      </div>
    </div>

    <!-- 兴趣与领域 -->
    <div class="interests-section">
      <h2>🎮 兴趣与专注领域</h2>
      <div class="interests-grid">
        <div class="interest-card">
          <div class="interest-icon">🎮</div>
          <h3>游戏开发</h3>
          <p>Unity、Godot 引擎探索，独立游戏制作人</p>
        </div>
        <div class="interest-card">
          <div class="interest-icon">🌐</div>
          <h3>全栈开发</h3>
          <p>从前端到后端，构建完整产品体验</p>
        </div>
        <div class="interest-card">
          <div class="interest-icon">🔒</div>
          <h3>网络安全</h3>
          <p>渗透测试、安全防护、CTF 爱好者</p>
        </div>
      </div>
    </div>

    <!-- 联系与社交区域 -->
    <div class="contact-section">
      <h2>📫 联系我</h2>
      <div class="contact-grid">
        <a
          href="mailto:your.email@example.com"
          class="contact-card"
          target="_blank"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
          <span>fenzestudio@163.com</span>
        </a>
        <a
          href="https://github.com/qiseer"
          class="contact-card"
          target="_blank"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48c-1.37-.38-2.82-.38-4.19 0C9.27.65 8.09 1 8.09 1A5.07 5.07 0 0 0 8 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 12 18.13V22"
            ></path>
          </svg>
          <span>GitHub</span>
        </a>
        <!-- <a
          href="https://twitter.com/yourusername"
          class="contact-card"
          target="_blank"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
            ></path>
          </svg>
          <span>Twitter</span>
        </a> -->
        <!-- <a
          href="https://linkedin.com/in/yourusername"
          class="contact-card"
          target="_blank"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
          <span>LinkedIn</span>
        </a> -->
      </div>
    </div>

    <!-- 个人小彩蛋：随机箴言 -->
    <div class="quote-section">
      <p id="random-quote" class="quote-text">✨ 加载中...</p>
    </div>
  </div>
</BaseLayout>

<style>
  .about-container {
    max-width: 80ch;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* 头像区域 - 移动端优化 */
  .profile-section {
    display: flex;
    gap: 2rem;
    align-items: center;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .avatar-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  .avatar {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-primary);
    transition: transform 0.3s ease;
    position: relative;
    z-index: 2;
  }

  .avatar-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      var(--color-primary-light),
      transparent
    );
    opacity: 0.6;
    filter: blur(10px);
    z-index: 1;
    transition: opacity 0.3s;
  }

  .avatar-wrapper:hover .avatar {
    transform: scale(1.02);
  }

  .avatar-wrapper:hover .avatar-glow {
    opacity: 0.9;
  }

  .profile-text {
    flex: 1;
    text-align: center;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .gradient-text {
    background: linear-gradient(
      135deg,
      var(--color-primary),
      var(--color-accent)
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .bio {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-primary);
  }

  /* 技能区域 */
  .skills-section,
  .interests-section,
  .contact-section {
    margin-bottom: 3rem;
  }

  h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1rem;
  }

  .skill-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    padding: 0.75rem 1rem;
    text-align: center;
    font-weight: 500;
    transition: all 0.2s ease;
    cursor: default;
  }

  .skill-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }

  .skill-planned {
    border-style: dashed;
    opacity: 0.8;
  }

  /* 兴趣卡片 */
  .interests-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .interest-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    padding: 1.5rem;
    text-align: center;
    transition: all 0.2s ease;
  }

  .interest-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .interest-icon {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .interest-card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
  }

  .interest-card p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  /* 联系方式区域 */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: all 0.2s ease;
  }

  .contact-card svg {
    flex-shrink: 0;
  }

  .contact-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-md);
  }

  /* 箴言区域 */
  .quote-section {
    text-align: center;
    padding: 2rem 1rem;
    background: var(--color-bg-surface);
    border-radius: 1.5rem;
    border: 1px solid var(--color-border);
  }

  .quote-text {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* 移动端专项优化 */
  @media (max-width: 640px) {
    .about-container {
      padding: 1rem;
    }

    .profile-section {
      flex-direction: column;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .avatar {
      width: 120px;
      height: 120px;
    }

    h1 {
      font-size: 1.75rem;
    }

    .tagline {
      font-size: 1rem;
    }

    .bio {
      font-size: 0.95rem;
    }

    h2 {
      font-size: 1.35rem;
      margin-bottom: 1rem;
    }

    .skills-grid {
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 0.75rem;
    }

    .skill-card {
      font-size: 0.9rem;
      padding: 0.6rem 0.8rem;
    }

    .interests-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .interest-card {
      padding: 1rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-card {
      justify-content: center;
    }

    .quote-section {
      padding: 1.5rem;
    }
  }

  /* 小屏手机进一步优化 */
  @media (max-width: 480px) {
    .avatar {
      width: 100px;
      height: 100px;
    }

    h1 {
      font-size: 1.5rem;
    }

    .tagline {
      font-size: 0.9rem;
    }

    .skills-grid {
      grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    }
  }
</style>

<script>
  // 随机箴言小彩蛋
  const quotes = [
    "💡 代码是写给人看的，只是顺便让机器执行。",
    "🚀 最好的时机是十年前，其次是现在。",
    "🧠 保持好奇，终身学习。",
    "🎨 设计不只是它看起来怎样，还在于它如何工作。",
    "🌱 每天进步一点点。",
    "🔧 先让它工作，再让它优雅。",
    "✨ 简单是可靠的先决条件。",
    "🎮 玩游戏不如做游戏，做游戏不如玩自己做的游戏。",
    "🔒 网络安全：攻防之间，见自己，见天地。",
  ];

  const randomIndex = Math.floor(Math.random() * quotes.length);
  const quoteEl = document.getElementById("random-quote");
  if (quoteEl) {
    quoteEl.textContent = quotes[randomIndex];
  }
</script>
