---
// src/pages/changelog.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// 可选：从内容集合读取更新日志，这里直接硬编码示例
const changelogEntries = [
  {
    version: "v1.0.0",
    date: "2025-03-22",
    title: "初始版本发布",
    changes: [
      "重构博客列表和详情页，支持标签和封面图",
      "新增暗色模式切换按钮，记忆用户偏好",
      "优化移动端显示，导航栏响应式菜单",
      "添加 404 页面，包含动态粒子效果",
      "基于 Astro 搭建博客框架",
      "实现基础布局和全局样式",
      "添加首页、关于页面",
      "支持 Markdown 文章",
      "添加个人简介和联系方式",
      "优化全局 CSS 变量，支持暗色模式",
      "增加随机箴言",
      "修复导航栏闪烁问题",
    ],
  },
];
---

<BaseLayout pageTitle="更新日志">
  <div class="changelog-container">
    <h1>更新日志</h1>
    <p class="subtitle">记录每一次迭代。</p>

    <div class="timeline">
      {
        changelogEntries.map((entry) => (
          <div class="timeline-item">
            <div class="timeline-badge">
              <span class="version">{entry.version}</span>
            </div>
            <div class="timeline-content">
              <div class="timeline-header">
                <h2>{entry.title}</h2>
                <time datetime={entry.date}>{entry.date}</time>
              </div>
              <ul class="change-list">
                {entry.changes.map((change) => (
                  <li>{change}</li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>

    <div class="footnote">
      <p>如有疑问或建议，欢迎 <a href="/about#contact">联系我</a>。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .changelog-container {
    max-width: 80ch;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
  }

  /* 时间线布局 */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2rem;
  }

  .timeline-badge {
    position: absolute;
    left: -2rem;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 4px var(--color-bg);
    z-index: 1;
  }

  .version {
    color: white;
    font-weight: bold;
    font-size: 0.7rem;
  }

  .timeline-content {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    margin-left: 1.5rem;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .timeline-content:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-md);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    gap: 0.5rem;
  }

  .timeline-header h2 {
    margin: 0;
    font-size: 1.3rem;
  }

  .timeline-header time {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
  }

  .change-list {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-text-primary);
  }

  .change-list li {
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .footnote {
    text-align: center;
    margin-top: 3rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .footnote a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .footnote a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .changelog-container {
      padding: 1rem;
    }
    .timeline {
      padding-left: 1rem;
    }
    .timeline::before {
      left: 0;
    }
    .timeline-badge {
      left: -1.5rem;
      width: 2rem;
      height: 2rem;
    }
    .version {
      font-size: 0.6rem;
    }
    .timeline-content {
      margin-left: 1rem;
      padding: 1rem;
    }
    .timeline-header h2 {
      font-size: 1.1rem;
    }
    .change-list li {
      font-size: 0.9rem;
    }
  }
</style>
