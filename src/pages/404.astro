---
// src/pages/404.astro
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>页面走丢了 | 404</title>
    <style>
      /* 全局重置和变量（继承你原有的配色） */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        background: var(--color-bg);
        color: var(--color-text-primary);
        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          "Helvetica Neue",
          sans-serif;
        overflow-x: hidden;
        position: relative;
      }

      /* 动态粒子画布 */
      #particle-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }

      /* 主要内容容器 */
      .error-container {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        padding: 2rem;
        backdrop-filter: blur(2px);
      }

      /* 404 数字卡片 */
      .glitch-card {
        background: var(--color-bg-surface);
        border-radius: 2rem;
        padding: 2rem 3rem;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--color-border);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
        max-width: 90%;
        animation: float 6s ease-in-out infinite;
      }

      .glitch-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-xl);
      }

      /* 404 数字带故障效果 */
      .error-code {
        font-size: clamp(6rem, 15vw, 12rem);
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(
          135deg,
          var(--color-primary),
          var(--color-accent)
        );
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        position: relative;
        display: inline-block;
      }

      .error-code::before,
      .error-code::after {
        content: "404";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          135deg,
          var(--color-primary),
          var(--color-accent)
        );
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        opacity: 0.8;
      }

      .error-code::before {
        animation: glitch 0.4s infinite;
        clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
        transform: translate(-2px, -2px);
      }

      .error-code::after {
        animation: glitch 0.4s infinite reverse;
        clip-path: polygon(0 80%, 100% 20%, 100% 100%, 0 100%);
        transform: translate(2px, 2px);
      }

      /* 标题和描述 */
      h1 {
        font-size: clamp(1.5rem, 5vw, 2rem);
        margin: 1rem 0 0.5rem;
        font-weight: 600;
      }

      .description {
        color: var(--color-text-secondary);
        max-width: 500px;
        margin: 1rem auto;
        font-size: 1.1rem;
      }

      /* 返回按钮 */
      .home-button {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.8rem 2rem;
        background: var(--color-primary);
        color: white;
        text-decoration: none;
        border-radius: 3rem;
        font-weight: 500;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        border: none;
        cursor: pointer;
      }

      .home-button:hover {
        background: var(--color-primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
      }

      /* 有趣的装饰元素 */
      .floating-emoji {
        position: absolute;
        font-size: 2rem;
        pointer-events: none;
        z-index: 1;
        animation: float-emoji 8s infinite ease-in-out;
      }

      /* 动画定义 */
      @keyframes float {
        0%,
        100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(-10px);
        }
      }

      @keyframes glitch {
        0% {
          transform: translate(0);
          opacity: 0.8;
        }
        20% {
          transform: translate(-2px, 2px);
        }
        40% {
          transform: translate(-2px, -2px);
        }
        60% {
          transform: translate(2px, 2px);
        }
        80% {
          transform: translate(2px, -2px);
        }
        100% {
          transform: translate(0);
          opacity: 0.8;
        }
      }

      @keyframes float-emoji {
        0% {
          transform: translateY(0) rotate(0deg);
          opacity: 0.6;
        }
        50% {
          transform: translateY(-20px) rotate(10deg);
          opacity: 1;
        }
        100% {
          transform: translateY(0) rotate(0deg);
          opacity: 0.6;
        }
      }

      /* 响应式调整 */
      @media (max-width: 640px) {
        .glitch-card {
          padding: 1.5rem;
        }
        .floating-emoji {
          font-size: 1.5rem;
        }
      }
    </style>
  </head>
  <body>
    <!-- 动态粒子背景画布 -->
    <canvas id="particle-canvas"></canvas>

    <!-- 浮动 Emoji 装饰（随机生成） -->
    <div
      class="floating-emoji"
      style="top: 10%; left: 5%; animation-delay: 0s;"
    >
      🕳️
    </div>
    <div
      class="floating-emoji"
      style="top: 70%; left: 85%; animation-delay: 1s;"
    >
      🔍
    </div>
    <div
      class="floating-emoji"
      style="top: 85%; left: 15%; animation-delay: 2s;"
    >
      🧭
    </div>
    <div
      class="floating-emoji"
      style="top: 20%; left: 90%; animation-delay: 3s;"
    >
      🚀
    </div>
    <div
      class="floating-emoji"
      style="top: 40%; left: 10%; animation-delay: 4s;"
    >
      🤔
    </div>
    <div
      class="floating-emoji"
      style="top: 60%; left: 80%; animation-delay: 5s;"
    >
      ✨
    </div>

    <div class="error-container">
      <div class="glitch-card">
        <div class="error-code">404</div>
        <h1>哎呀，页面走丢了！</h1>
        <p class="description">
          看起来你来到了一个不存在的地方。<br />
          可能是链接有误，或者页面已被移走。
        </p>
        <a href="/" class="home-button">🏠 返回首页</a>
      </div>
    </div>

    <script>
      (function () {
        // 类型安全的元素获取
        const canvas = document.getElementById(
          "particle-canvas",
        ) as HTMLCanvasElement | null;
        if (!canvas) return;

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        let width = window.innerWidth;
        let height = window.innerHeight;

        // 定义粒子类型
        interface Particle {
          x: number;
          y: number;
          radius: number;
          alpha: number;
          speedX: number;
          speedY: number;
        }

        let particles: Particle[] = [];

        function resizeCanvas() {
          if (!canvas) return;
          width = window.innerWidth;
          height = window.innerHeight;
          canvas.width = width;
          canvas.height = height;
        }

        function initParticles() {
          particles = [];
          const particleCount = Math.min(
            80,
            Math.floor((width * height) / 8000),
          );
          for (let i = 0; i < particleCount; i++) {
            particles.push({
              x: Math.random() * width,
              y: Math.random() * height,
              radius: Math.random() * 3 + 1,
              alpha: Math.random() * 0.5 + 0.2,
              speedX: (Math.random() - 0.5) * 0.5,
              speedY: (Math.random() - 0.5) * 0.5,
            });
          }
        }

        function drawParticles() {
          if (!ctx) return;
          ctx.clearRect(0, 0, width, height);
          // 根据当前主题获取粒子颜色
          const isDark = document.documentElement.classList.contains("dark");
          const color = isDark
            ? "rgba(255, 255, 255, 0.3)"
            : "rgba(0, 0, 0, 0.2)";
          for (const p of particles) {
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
            ctx.fillStyle = color;
            ctx.fill();
          }
        }

        function updateParticles() {
          for (const p of particles) {
            p.x += p.speedX;
            p.y += p.speedY;
            if (p.x < -10) p.x = width + 10;
            if (p.x > width + 10) p.x = -10;
            if (p.y < -10) p.y = height + 10;
            if (p.y > height + 10) p.y = -10;
          }
        }

        function animate() {
          updateParticles();
          drawParticles();
          requestAnimationFrame(animate);
        }

        window.addEventListener("resize", () => {
          resizeCanvas();
          initParticles();
        });

        // 监听主题变化，重绘时颜色自动适配
        const observer = new MutationObserver(() => {
          drawParticles();
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });

        resizeCanvas();
        initParticles();
        animate();
      })();
    </script>

    <style>
      /* 补充定义可能未声明的 CSS 变量（如果全局没有，这里作为后备） */
      :root {
        --color-bg: #f8fafc;
        --color-bg-surface: #ffffff;
        --color-border: #e2e8f0;
        --color-text-primary: #0f172a;
        --color-text-secondary: #475569;
        --color-primary: #0d9488;
        --color-primary-hover: #0f766e;
        --color-accent: #f59e0b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
        --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
      }
      html.dark {
        --color-bg: #0f172a;
        --color-bg-surface: #1e293b;
        --color-border: #334155;
        --color-text-primary: #f1f5f9;
        --color-text-secondary: #cbd5e1;
        --color-primary: #2dd4bf;
        --color-primary-hover: #5eead4;
        --color-accent: #fbbf24;
      }
    </style>
  </body>
</html>
